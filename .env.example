# =============================================================================
# Variáveis de ambiente — EXEMPLO
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no .env
#   3. NUNCA faça commit do .env (ele está no .gitignore)
#
# No servidor de produção, este arquivo fica em:
#   /home/ghactions/mercado/.env
# A variável APP_IMAGE é atualizada automaticamente pelo GitHub Actions.
# =============================================================================

# Imagem Docker da aplicação (atualizada automaticamente pelo CI/CD a cada deploy)
# Substitua pelo seu usuário ou organização no GitHub.
APP_IMAGE=ghcr.io/des-sist-corp-ufpb/projeto-eq09:latest

# Banco de dados (Produção eq09)
DATABASE_NAME=eq09
DATABASE_URL=jdbc:postgresql://postgres:5432/eq09
DATABASE_USERNAME=eq09
DATABASE_PASSWORD=yzdS9dSAaE3YP63gDZmE

# Porta da aplicação no servidor (Produção eq09)
SERVER_PORT=8109

# Object Storage / MinIO (Produção eq09)
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_PUBLIC_ENDPOINT=https://s3.dsc.rodrigor.com
AWS_S3_BUCKET=eq09
AWS_S3_ACCESS_KEY=eq09
AWS_S3_SECRET_KEY=01nXvfGS3LUOABjTxleE0Jy7
AWS_S3_REGION=us-east-1

# OpenTelemetry / Observabilidade (LGTM)
# Se rodar a app via docker, endpoint deve apontar para http://otel-lgtm:4318
# Se rodar a app localmente (máquina), use http://localhost:4318
OTEL_SERVICE_NAME=eq09-DSCboxd
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

